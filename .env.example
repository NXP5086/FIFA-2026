# Copy this file to .env and fill in your values.

# Supabase — from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Supabase service role key (bypasses RLS — server-side / Vercel function only, never expose to browser)
# From: Supabase → Settings → API → "service_role" key (the long JWT)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# api-football.com (RapidAPI) live scores — 100 req/day free
# Sign up at: https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=YOUR_RAPIDAPI_KEY_HERE
