# Copy this file to .env and fill in your values.

# Supabase — from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Supabase service role key (bypasses RLS — server-side / Vercel function only, never expose to browser)
# From: Supabase → Settings → API → "service_role" key (the long JWT)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# football-data.org live scores API
# Sign up at: https://www.football-data.org/client/register (free tier works)
# €12/mo livescores plan gives real-time in-play scores instead of delayed
FOOTBALL_DATA_API_KEY=YOUR_API_KEY_HERE
